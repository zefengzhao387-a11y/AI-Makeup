APP_ENV=development

SECRET_KEY=change-me-please-use-a-long-random-string-in-production

# 本地开发用 SQLite；Vercel + Prisma Postgres 用 postgres:// 连接串（见 README）
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

JWT_EXPIRE_DAYS=7

# 化妆 AI / 图像编辑（Stability AI）— 本地与 Vercel 环境变量均需配置
STABILITY_API_KEY=

CORS_ORIGINS=*

# ── 前端（可选）──────────────────────────────────────────
# 本地默认走 Vite 代理，无需设置
# Vercel 同域部署留空即可；前后端分离时设为完整 API 前缀，如 https://xxx.vercel.app/api
# VITE_API_BASE=/api
