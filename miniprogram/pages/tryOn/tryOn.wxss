.page { padding: 30rpx; }
.to-head { text-align: center; margin-bottom: 40rpx; }
.to-title { font-size: 40rpx; font-weight: 700; display: block; }
.to-sub { font-size: 26rpx; display: block; margin-top: 6rpx; }

.upload-area { border: 3rpx dashed #F0EDE8; border-radius: 20rpx; padding: 80rpx 40rpx; text-align: center; display: flex; flex-direction: column; align-items: center; }

.preview { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.preview-col { flex: 1; }
.preview-label { font-size: 22rpx; font-weight: 600; letter-spacing: 2rpx; text-transform: uppercase; display: block; margin-bottom: 8rpx; }
.preview-img { width: 100%; aspect-ratio: 1; border-radius: 16rpx; border: 2rpx solid #F0EDE8; }
.preview-placeholder { width: 100%; aspect-ratio: 1; border-radius: 16rpx; border: 2rpx solid #F0EDE8; background: #FAF9F6; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }

.action-bar { display: flex; gap: 14rpx; align-items: center; }
.prompt-input { flex: 1; padding: 20rpx 28rpx; border: 2rpx solid #F0EDE8; border-radius: 50rpx; font-size: 28rpx; }
.apply-btn { padding: 20rpx 36rpx; font-size: 26rpx; min-width: auto; }

.error-text { color: #C45B5B; font-size: 26rpx; display: block; margin-top: 16rpx; text-align: center; }
.reset-link { text-align: center; margin-top: 24rpx; }
