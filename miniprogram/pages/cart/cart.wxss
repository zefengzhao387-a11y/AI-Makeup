.page { padding: 30rpx; padding-bottom: 40rpx; }
.head { margin-bottom: 24rpx; }
.sec-title { font-size: 40rpx; font-weight: 700; }

.ci { display: flex; gap: 24rpx; padding: 24rpx 0; border-bottom: 2rpx solid #F0EDE8; }
.ci-img { width: 160rpx; height: 200rpx; border-radius: 12rpx; }
.ci-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.ci-name { font-size: 28rpx; display: block; margin-bottom: 6rpx; }
.ci-price { font-size: 28rpx; display: block; margin-bottom: 12rpx; }
.ci-qty { display: flex; align-items: center; gap: 18rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border: 2rpx solid #F0EDE8; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.qty-num { min-width: 40rpx; text-align: center; }
.ci-remove { margin-left: 20rpx; font-size: 24rpx; color: #C45B5B; }

.summary { margin-top: 30rpx; padding-top: 24rpx; border-top: 4rpx solid #18181B; }
.summary-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; font-size: 30rpx; }
.summary-btn { width: 100%; }
