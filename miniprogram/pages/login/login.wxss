.page { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 40rpx; }
.auth-card { width: 100%; max-width: 640rpx; text-align: center; }
.auth-title { font-size: 44rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.auth-sub { font-size: 26rpx; display: block; margin-bottom: 48rpx; }

.fg { margin-bottom: 24rpx; text-align: left; }
.fg-label { font-size: 22rpx; font-weight: 600; letter-spacing: 2rpx; text-transform: uppercase; display: block; margin-bottom: 10rpx; }
.fg-input { width: 100%; padding: 22rpx 28rpx; border: 2rpx solid #F0EDE8; border-radius: 14rpx; font-size: 28rpx; }

.error-text { color: #C45B5B; font-size: 26rpx; display: block; margin: 12rpx 0; }

.submit-btn { width: 100%; margin-top: 12rpx; }
.switch-link { margin-top: 32rpx; font-size: 26rpx; }
