<view class="page">
  <!-- 未登录 -->
  <view wx:if="{{!loggedIn}}" class="empty">
    <text class="title">尚未登录</text>
    <text class="desc">登录后享受完整功能</text>
    <button class="btn btn-p login-btn" bindtap="onLogin">去登录</button>
  </view>

  <!-- 已登录 -->
  <view wx:else>
    <view class="pf-card">
      <view class="pf-avatar"><text class="pf-av-text">L</text></view>
      <text class="pf-name serif fw6">Beauty Lover</text>
      <text class="pf-id sub">User #{{userId}}</text>
    </view>

    <view class="menu">
      <view class="menu-item" bindtap="onFavorites">
        <text>❤️ 我的收藏</text>
        <text class="sub">{{favCount}} 件</text>
      </view>
      <view class="divider"></view>
      <view class="menu-item" bindtap="onTryOn">
        <text>📸 AI 试妆</text>
        <text class="sub">→</text>
      </view>
      <view class="divider"></view>
      <view class="menu-item danger" bindtap="onLogout">
        <text>退出登录</text>
        <text class="sub">→</text>
      </view>
    </view>
  </view>
</view>
