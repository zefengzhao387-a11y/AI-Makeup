.page { padding: 30rpx; }

.pf-card { background: #fff; border-radius: 24rpx; padding: 48rpx; text-align: center; border: 2rpx solid #F0EDE8; margin-bottom: 30rpx; }
.pf-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: linear-gradient(135deg, #C8956C, #E8C4A8); display: flex; align-items: center; justify-content: center; margin: 0 auto 18rpx; }
.pf-av-text { font-size: 48rpx; color: #fff; font-family: Georgia, serif; }
.pf-name { font-size: 36rpx; display: block; margin-bottom: 4rpx; }
.pf-id { font-size: 26rpx; display: block; }

.menu { background: #fff; border-radius: 20rpx; border: 2rpx solid #F0EDE8; overflow: hidden; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 28rpx; font-size: 28rpx; }
.menu-item.danger { color: #C45B5B; }

.login-btn { margin-top: 30rpx; width: 60%; }
