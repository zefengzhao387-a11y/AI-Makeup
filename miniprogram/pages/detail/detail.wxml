<view class="page" wx:if="{{!loading && product}}">
  <!-- 顶部返回栏 -->
  <view class="det-topbar">
    <view class="det-back" bindtap="onBack">
      <text class="det-back-arrow">←</text>
      <text>返回</text>
    </view>
    <view class="det-actions">
      <text class="det-action" bindtap="onTryOn">✨ AI试妆</text>
    </view>
  </view>

  <image class="det-img" src="{{product.image_url||'https://images.unsplash.com/photo-1586495777744-4413f21062fa?w=600&q=80'}}" mode="aspectFill" />

  <view class="det-body">
    <text class="det-brand accent fw6" wx:if="{{product.brand}}">{{product.brand}}</text>
    <text class="det-name serif">{{product.name}}</text>
    <text class="det-price accent fw6">¥{{product.price||'—'}}</text>

    <view wx:if="{{product.description}}" class="det-sec">
      <text class="det-desc sub">{{product.description}}</text>
    </view>

    <view wx:if="{{product.ingredients}}" class="det-sec">
      <text class="det-label sub">成分</text>
      <text class="det-text">{{product.ingredients}}</text>
    </view>

    <view wx:if="{{product.usage_tips}}" class="det-sec">
      <text class="det-label sub">使用方法</text>
      <text class="det-text">{{product.usage_tips}}</text>
    </view>

    <view wx:if="{{product.skin_tones.length || product.face_shapes.length}}" class="det-sec">
      <text class="det-label sub">推荐人群</text>
      <view class="det-tags">
        <text wx:for="{{product.skin_tones}}" wx:key="*this" class="tag">肤色: {{item}}</text>
        <text wx:for="{{product.face_shapes}}" wx:key="*this" class="tag">脸型: {{item}}</text>
      </view>
    </view>
  </view>

  <!-- 评论区块 -->
  <view class="det-reviews">
    <text class="det-rev-title">用户评价{{product.review_count ? ' (' + product.review_count + ')' : ''}}</text>
    <view wx:if="{{product.rating}}" class="det-rev-avg">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="star {{item <= product.rating ? 'on' : ''}}">★</text>
      <text class="sub" style="margin-left:8rpx">{{product.rating}}</text>
    </view>

    <!-- 提交评论 -->
    <view class="det-rev-form" wx:if="{{app.isLoggedIn()}}">
      <view class="det-rev-rate">
        <text class="sub">我的评分：</text>
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
          class="star star-tap {{item <= myRating ? 'on' : ''}}"
          bindtap="onRateTap" data-r="{{item}}">★</text>
      </view>
      <textarea class="det-rev-input" value="{{myText}}" placeholder="分享你的使用感受..."
        bindinput="onRevInput" maxlength="500"/>
      <button class="btn btn-p" style="margin-top:12rpx;width:100%" bindtap="onSubmitReview"
        disabled="{{submitting || !myText}}">{{submitting ? '提交中...' : '发表评价'}}</button>
    </view>
    <view wx:else class="det-rev-login">
      <text class="sub">请登录后发表评价</text>
    </view>

    <!-- 评论列表 -->
    <view wx:if="{{reviews.length === 0}}" class="det-rev-empty">
      <text class="sub">暂无评价，成为第一个评价的人吧</text>
    </view>
    <view wx:for="{{reviews}}" wx:key="id" class="det-rev-item">
      <view class="det-rev-head">
        <view class="det-rev-avatar">{{(item.nickname || '匿')[0]}}</view>
        <text class="det-rev-nick">{{item.nickname || '匿名用户'}}</text>
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="star {{index < item.rating ? 'on' : ''}}">★</text>
      </view>
      <text class="det-rev-text">{{item.content}}</text>
    </view>
  </view>

  <!-- Bottom bar -->
  <view class="bot-bar">
    <view class="bot-fav" bindtap="onToggleFav">
      <text style="font-size:40rpx">{{isFav ? '❤️' : '🤍'}}</text>
      <text class="bot-fav-txt sub">{{isFav ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="btn btn-p bot-cart" bindtap="onAddCart">加入购物车</button>
  </view>
</view>

<view wx:if="{{loading}}" style="text-align:center;padding:120rpx"><text class="sub">Loading…</text></view>
