<view class="page" wx:if="{{!loading && product}}">
  <image class="det-img" src="{{product.image_url||'https://images.unsplash.com/photo-1586495777744-4413f21062fa?w=600&q=80'}}" mode="aspectFill" />

  <view class="det-body">
    <text class="det-brand accent fw6" wx:if="{{product.brand}}">{{product.brand}}</text>
    <text class="det-name serif">{{product.name}}</text>
    <text class="det-price accent fw6">¥{{product.price||'—'}}</text>

    <view wx:if="{{product.description}}" class="det-sec">
      <text class="det-desc sub">{{product.description}}</text>
    </view>

    <view wx:if="{{product.ingredients}}" class="det-sec">
      <text class="det-label sub">成分</text>
      <text class="det-text">{{product.ingredients}}</text>
    </view>

    <view wx:if="{{product.usage_tips}}" class="det-sec">
      <text class="det-label sub">使用方法</text>
      <text class="det-text">{{product.usage_tips}}</text>
    </view>

    <view wx:if="{{product.skin_tones.length || product.face_shapes.length}}" class="det-sec">
      <text class="det-label sub">推荐人群</text>
      <view class="det-tags">
        <text wx:for="{{product.skin_tones}}" wx:key="*this" class="tag">肤色: {{item}}</text>
        <text wx:for="{{product.face_shapes}}" wx:key="*this" class="tag">脸型: {{item}}</text>
      </view>
    </view>
  </view>

  <!-- Bottom bar -->
  <view class="bot-bar">
    <view class="bot-fav" bindtap="onToggleFav">
      <text style="font-size:40rpx">{{isFav ? '❤️' : '🤍'}}</text>
      <text class="bot-fav-txt sub">{{isFav ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="btn btn-p bot-cart" bindtap="onAddCart">加入购物车</button>
  </view>
</view>

<view wx:if="{{loading}}" style="text-align:center;padding:120rpx"><text class="sub">Loading…</text></view>
