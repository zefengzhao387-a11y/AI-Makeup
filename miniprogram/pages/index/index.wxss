.page { padding-bottom: 30rpx; }
.hero { margin: 24rpx 30rpx; padding: 56rpx 40rpx; background: linear-gradient(135deg,#F5EDE4 0%,#FDF6EE 50%,#EDE6DA 100%); border-radius: 24rpx; }
.hero-title { font-size: 48rpx; font-weight: 700; line-height: 1.2; display: block; }
.hero-sub { display: block; margin-top: 12rpx; font-size: 26rpx; }
.hero-btn { margin-top: 28rpx; display: inline-flex; padding: 20rpx 40rpx; font-size: 26rpx; }

.tabs-wrap { white-space: nowrap; padding: 20rpx 30rpx; }
.tab { display: inline-block; padding: 14rpx 30rpx; margin-right: 14rpx; border: 2rpx solid #F0EDE8; border-radius: 40rpx; font-size: 26rpx; font-weight: 500; }
.tab.on { background: #18181B; color: #fff; border-color: #18181B; }

.grid { display: flex; flex-wrap: wrap; padding: 0 24rpx; gap: 16rpx; }
.pcard { width: calc(50% - 8rpx); position: relative; }
.pcard-img { width: 100%; height: 380rpx; }
.pcard-body { padding: 18rpx; }
.pcard-brand { font-size: 20rpx; letter-spacing: 2rpx; text-transform: uppercase; display: block; margin-bottom: 4rpx; }
.pcard-name { font-size: 26rpx; display: block; margin-bottom: 6rpx; line-height: 1.3; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.pcard-price { font-size: 28rpx; display: block; }
.pcard-tags { margin-top: 6rpx; }
