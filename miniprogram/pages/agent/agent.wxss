.page { display: flex; flex-direction: column; min-height: 100vh; padding-bottom: 130rpx; }
.ag-head { text-align: center; padding: 30rpx 0 20rpx; }
.ag-title { font-size: 40rpx; font-weight: 700; display: block; }
.ag-sub { font-size: 26rpx; display: block; margin-top: 6rpx; }

.msgs { flex: 1; padding: 20rpx 30rpx; }
.msg { max-width: 82%; padding: 22rpx 28rpx; border-radius: 24rpx; margin-bottom: 20rpx; font-size: 28rpx; line-height: 1.65; }
.msg-u { margin-left: auto; background: #18181B; color: #fff; border-bottom-right-radius: 6rpx; }
.msg-a { margin-right: auto; background: #fff; border: 2rpx solid #F0EDE8; border-bottom-left-radius: 6rpx; }
.msg-text { display: block; white-space: pre-wrap; }

.recs { margin-top: 14rpx; }
.rec-card { display: inline-block; padding: 12rpx 22rpx; margin: 6rpx 8rpx 0 0; background: #FAF9F6; border-radius: 12rpx; border: 2rpx solid #F0EDE8; font-size: 24rpx; }

.input-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 2rpx solid #F0EDE8; padding: 16rpx 24rpx; display: flex; gap: 16rpx; align-items: center; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }
.input-field { flex: 1; padding: 20rpx 28rpx; border: 2rpx solid #F0EDE8; border-radius: 50rpx; font-size: 28rpx; }
.send-btn { padding: 20rpx 36rpx; font-size: 26rpx; min-width: auto; }
