/* miniprogram/app.wxss */
page { background: #FAF9F6; color: #18181B; font-family: -apple-system, 'PingFang SC', sans-serif; font-size: 28rpx; line-height: 1.6; }
.accent { color: #C8956C; }
.sub { color: #9CA3AF; }
.serif { font-family: Georgia, 'Songti SC', serif; }
.fw6 { font-weight: 600; }

.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx 40rpx; border-radius: 60rpx; font-size: 28rpx; font-weight: 600; border: none; line-height: 1; }
.btn::after { border: none; }
.btn-p { background: #18181B; color: #fff; }
.btn-a { background: #C8956C; color: #fff; }
.btn-o { background: transparent; border: 2rpx solid #F0EDE8; color: #18181B; }

.card { background: #fff; border-radius: 20rpx; overflow: hidden; border: 2rpx solid #F0EDE8; }
.tag { display: inline-block; padding: 6rpx 16rpx; background: #FAF9F6; border-radius: 30rpx; font-size: 22rpx; color: #9CA3AF; margin-right: 8rpx; margin-top: 8rpx; }
.divider { height: 2rpx; background: #F0EDE8; }
.empty { text-align: center; padding: 120rpx 60rpx; }
.empty .title { font-family: Georgia, serif; font-size: 36rpx; font-weight: 600; margin-bottom: 12rpx; }
.empty .desc { color: #9CA3AF; font-size: 26rpx; }
